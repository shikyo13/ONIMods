# ── Options — Properties ──

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.SORTORDER.NAME"
msgid "Sort Order"
msgstr "Ordre de tri"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.SORTORDER.DESC"
msgid "How to sort duplicants in the bar."
msgstr "Comment trier les duplicants dans la barre."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.PORTRAITSIZE.NAME"
msgid "Portrait Size"
msgstr "Taille du portrait"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.PORTRAITSIZE.DESC"
msgid "Size of each portrait in pixels."
msgstr "Taille de chaque portrait en pixels."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MAXDUPESPERROW.NAME"
msgid "Max Dupes Per Row"
msgstr "Duplicants max par ligne"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MAXDUPESPERROW.DESC"
msgid "Maximum portraits per row (0 = auto-fit to screen width)."
msgstr "Portraits maximum par ligne (0 = ajustement auto à la largeur)."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MAXBARWIDTH.NAME"
msgid "Max Bar Width (%)"
msgstr "Largeur max de la barre (%)"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MAXBARWIDTH.DESC"
msgid "Maximum bar width as percentage of screen (triggers row wrapping)."
msgstr "Largeur max de la barre en % de l'écran (déclenche le retour à la ligne)."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MAXROWS.NAME"
msgid "Max Rows"
msgstr "Lignes max"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MAXROWS.DESC"
msgid "Maximum visible rows before scrolling (0 = unlimited)."
msgstr "Lignes visibles max avant défilement (0 = illimité)."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.BAROPACITY.NAME"
msgid "Bar Opacity (%)"
msgstr "Opacité de la barre (%)"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.BAROPACITY.DESC"
msgid "Opacity of the status bar background."
msgstr "Opacité de l'arrière-plan de la barre d'état."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.DISPLAYMODE.NAME"
msgid "Display Mode"
msgstr "Mode d'affichage"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.DISPLAYMODE.DESC"
msgid "Show portraits or initial letters."
msgstr "Afficher les portraits ou les initiales."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.FACEEXPRESSIONS.NAME"
msgid "Face Expressions"
msgstr "Expressions faciales"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.FACEEXPRESSIONS.DESC"
msgid "Show dynamic facial expressions based on dupe status."
msgstr "Afficher les expressions faciales dynamiques selon l'état du duplicant."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.CALMTHRESHOLD.NAME"
msgid "Calm Threshold"
msgstr "Seuil calme"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.CALMTHRESHOLD.DESC"
msgid "Stress below this % is Calm (green)."
msgstr "Le stress sous ce % est Calme (vert)."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MILDTHRESHOLD.NAME"
msgid "Mild Threshold"
msgstr "Seuil léger"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.MILDTHRESHOLD.DESC"
msgid "Stress below this % is Mild (lime)."
msgstr "Le stress sous ce % est Léger (citron vert)."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.STRESSEDTHRESHOLD.NAME"
msgid "Stressed Threshold"
msgstr "Seuil stressé"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.STRESSEDTHRESHOLD.DESC"
msgid "Stress below this % is Stressed (yellow)."
msgstr "Le stress sous ce % est Stressé (jaune)."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.HIGHTHRESHOLD.NAME"
msgid "High Threshold"
msgstr "Seuil élevé"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.HIGHTHRESHOLD.DESC"
msgid "Stress below this % is High (orange)."
msgstr "Le stress sous ce % est Élevé (orange)."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSUFFOCATING.NAME"
msgid "Suffocating Alert"
msgstr "Alerte suffocation"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSUFFOCATING.DESC"
msgid "Show badge when dupe is suffocating."
msgstr "Afficher le badge quand le duplicant suffoque."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTLOWHP.NAME"
msgid "Low HP Alert"
msgstr "Alerte santé faible"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTLOWHP.DESC"
msgid "Show badge when dupe health is low."
msgstr "Afficher le badge quand la santé du duplicant est faible."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSCALDING.NAME"
msgid "Scalding Alert"
msgstr "Alerte brûlure"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSCALDING.DESC"
msgid "Show badge when dupe is overheating."
msgstr "Afficher le badge quand le duplicant surchauffe."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTHYPOTHERMIA.NAME"
msgid "Hypothermia Alert"
msgstr "Alerte hypothermie"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTHYPOTHERMIA.DESC"
msgid "Show badge when dupe is freezing."
msgstr "Afficher le badge quand le duplicant gèle."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTDISEASED.NAME"
msgid "Disease Alert"
msgstr "Alerte maladie"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTDISEASED.DESC"
msgid "Show badge when dupe is sick."
msgstr "Afficher le badge quand le duplicant est malade."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTOVERSTRESSED.NAME"
msgid "Overstressed Alert"
msgstr "Alerte surmené"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTOVERSTRESSED.DESC"
msgid "Show badge at critical stress."
msgstr "Afficher le badge en cas de stress critique."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTOVERJOYED.NAME"
msgid "Overjoyed Alert"
msgstr "Alerte euphorique"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTOVERJOYED.DESC"
msgid "Show rainbow border and tooltip during joy reactions."
msgstr "Afficher une bordure arc-en-ciel et une infobulle lors des réactions de joie."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTIRRADIATED.NAME"
msgid "Irradiated Alert"
msgstr "Alerte irradiation"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTIRRADIATED.DESC"
msgid "Show badge when dupe has radiation sickness."
msgstr "Afficher le badge quand le duplicant est irradié."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSTARVING.NAME"
msgid "Starving Alert"
msgstr "Alerte famine"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSTARVING.DESC"
msgid "Show badge when dupe is starving."
msgstr "Afficher le badge quand le duplicant est affamé."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTBLADDER.NAME"
msgid "Bladder Alert"
msgstr "Alerte vessie"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTBLADDER.DESC"
msgid "Show badge when dupe urgently needs a bathroom."
msgstr "Afficher le badge quand le duplicant a un besoin urgent de toilettes."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSTUCK.NAME"
msgid "Stuck Alert"
msgstr "Alerte coincé"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTSTUCK.DESC"
msgid "Show badge when dupe cannot reach the printing pod."
msgstr "Afficher le badge quand le duplicant ne peut pas atteindre le pod d'impression."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTIDLE.NAME"
msgid "Idle Alert"
msgstr "Alerte inactif"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTIDLE.DESC"
msgid "Show badge when dupe has no task for an extended period."
msgstr "Afficher le badge quand le duplicant est sans tâche pendant longtemps."

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTINCAPACITATED.NAME"
msgid "Incapacitated Alert"
msgstr "Alerte incapacité"

msgctxt "STRINGS.DUPLICANTSTATUSBAR.OPTIONS.ALERTINCAPACITATED.DESC"
msgid "Show badge when dupe is incapacitated (bleeding out)."
msgstr "Afficher le badge quand le duplicant est incapacité (hémorragie)."
